root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
indent_style = space
indent_size = 2
trim_trailing_whitespace = true

[*.rs]
indent_size = 4

[*.go]
indent_style = tab
indent_size = 4
tab_width = 4

[*.py]
indent_size = 4

[{Makefile,*.mk}]
indent_style = tab

[*.md]
trim_trailing_whitespace = false

[*.{yaml,yml,json,jsonc,js,jsx,ts,tsx,proto,toml}]
indent_size = 2
